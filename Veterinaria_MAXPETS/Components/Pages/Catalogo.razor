private async Task CargarServicios(int especialidadId)
{
    try
    {
        var http = HttpClientFactory.CreateClient("ApiProfesor");

        var todos = await http.GetFromJsonAsync<List<ServicioApi>>(
            "/Servicios");

        if (todos != null)
        {
            serviciosFiltrados = especialidadId == 0
                ? todos
                : todos.Where(s => s.EspecialidadId == especialidadId).ToList();
        }

        errorMensaje = null;
    }
    catch
    {
        errorMensaje = "No se pudo conectar con la API.";
        serviciosFiltrados = new List<ServicioApi>();

    }
   }
 }
